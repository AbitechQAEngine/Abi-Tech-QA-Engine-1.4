# ==============================================================================
# ABI-TECH QA-Engine — Environment Configuration Template
# Instructions: Copy this file, rename it to `.env`, and fill in the values.
# DO NOT commit the actual `.env` file to Git.
# ==============================================================================

# PostgreSQL Connection String (e.g., Supabase)
# Replace placeholders with your database credentials
DATABASE_URL=postgresql://[USERNAME]:[PASSWORD]@[HOST]:5432/[DATABASE]

# Security & Authentication
# A long, secure random string used to sign JWT tokens
SECRET_KEY=your_secret_key_here

# Third-Party API Keys
# Your secret key for Groq AI inference services
GROQ_API_KEY=gsk_your_groq_api_key_here

# Cross-Origin Resource Sharing (CORS) Setup
# Comma-separated list of allowed frontend URLs
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Email Notification Settings (Gmail SMTP)
# Leave SMTP_PASSWORD blank during local testing to print emails to the console logs.
# For live email delivery, provide a 16-character Google App Password.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=abitechqaengine@gmail.com
SMTP_PASSWORD=your_16_char_gmail_app_password
SMTP_FROM=abitechqaengine@gmail.com